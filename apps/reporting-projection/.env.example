APP_NAME=reporting-projection
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=json
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=reporting_projection
DB_USERNAME=postgres
DB_PASSWORD=

QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CORRELATION_ID_HEADER=X-Correlation-ID

KAFKA_BROKERS=kafka:9092
KAFKA_CONSUMER_GROUP_ID=reporting-projection
KAFKA_CLIENT_ID=reporting-projection-consumer
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_TOPIC_PAYMENTS_LIFECYCLE=payments.lifecycle.v1
KAFKA_TOPIC_REFUNDS_LIFECYCLE=refunds.lifecycle.v1
