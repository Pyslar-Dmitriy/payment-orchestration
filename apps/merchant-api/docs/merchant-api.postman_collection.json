{
  "info": {
    "name": "Merchant API",
    "_postman_id": "merchant-api-v1",
    "description": "Manual test collection for the merchant-api service.\n\nWorkflow:\n1. Run **Create Merchant** — the response contains `api_key.key`.\n2. Copy that value into the collection variable `api_key`.\n3. All authenticated requests use `Bearer {{api_key}}` automatically.\n\nBase URL is controlled by the `base_url` variable (default: http://localhost:8001).\nTraffic is routed through the nginx container on port 8001 — the merchant-api php-fpm container has no directly exposed port.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8001",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "",
      "type": "string",
      "description": "Plaintext API key (pk_live_...). Set automatically by the Create Merchant post-response script, or paste manually."
    },
    {
      "key": "payment_id",
      "value": "",
      "type": "string",
      "description": "Payment ID returned by Initiate Payment. Set automatically by the post-response script."
    },
    {
      "key": "refund_id",
      "value": "",
      "type": "string",
      "description": "Refund ID returned by Initiate Refund. Set automatically by the post-response script."
    }
  ],
  "item": [
    {
      "name": "Infrastructure",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Liveness probe. Returns 200 when the application boots correctly."
          },
          "response": []
        },
        {
          "name": "Ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ready",
              "host": ["{{base_url}}"],
              "path": ["ready"]
            },
            "description": "Readiness probe. Returns 200 when dependencies (DB, cache) are reachable."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Merchant Onboarding",
      "item": [
        {
          "name": "Create Merchant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.api_key && json.api_key.key) {",
                  "    pm.collectionVariables.set('api_key', json.api_key.key);",
                  "    console.log('api_key saved:', json.api_key.key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"email\": \"admin@acme.example\",\n  \"callback_url\": \"https://acme.example/webhooks/payments\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/merchants",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "merchants"]
            },
            "description": "Register a new merchant. Returns the merchant record and a one-time plaintext API key.\n\nThe post-response script automatically writes `api_key.key` into the `api_key` collection variable so subsequent authenticated requests work without manual copy-paste.\n\n**Required fields:** `name`, `email`\n**Optional fields:** `callback_url`"
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"merchant_id\": \"01HXYZ...\",\n  \"name\": \"Acme Corp\",\n  \"email\": \"admin@acme.example\",\n  \"api_key\": {\n    \"id\": \"01HABC...\",\n    \"key\": \"pk_live_a1b2c3d4...\",\n    \"key_prefix\": \"pk_live_a1b2\",\n    \"created_at\": \"2026-04-06T10:00:00Z\"\n  }\n}"
            },
            {
              "name": "422 Duplicate email",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"The email has already been taken.\",\n  \"errors\": {\n    \"email\": [\"The email has already been taken.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Create Merchant — missing required fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/merchants",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "merchants"]
            },
            "description": "Expect 422 with validation errors for `name` and `email`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authenticated — Merchant",
      "item": [
        {
          "name": "Show Current Merchant",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/merchants/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "merchants", "me"]
            },
            "description": "Returns the merchant record for the authenticated API key.\n\nExpect 401 if `api_key` variable is empty or the key is expired/unknown."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"merchant_id\": \"01HXYZ...\",\n  \"name\": \"Acme Corp\",\n  \"email\": \"admin@acme.example\",\n  \"status\": \"active\",\n  \"callback_url\": \"https://acme.example/webhooks/payments\"\n}"
            },
            {
              "name": "401 Missing key",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Missing API key.\"\n}"
            },
            {
              "name": "401 Invalid / expired key",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Invalid or expired API key.\"\n}"
            }
          ]
        },
        {
          "name": "Show Current Merchant — no auth",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/merchants/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "merchants", "me"]
            },
            "description": "Omits Authorization header. Expect 401 Missing API key."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authenticated — Payments",
      "item": [
        {
          "name": "Initiate Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.payment_id) {",
                  "    pm.collectionVariables.set('payment_id', json.payment_id);",
                  "    console.log('payment_id saved:', json.payment_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Accept",          "value": "application/json" },
              { "key": "Authorization",   "value": "Bearer {{api_key}}" },
              { "key": "Idempotency-Key", "value": "order-acme-00001", "description": "Optional. Repeat with the same value to get a cached response." },
              { "key": "X-Correlation-ID","value": "local-test-001",   "description": "Optional. Propagated through to payment-domain and included in the response." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 9900,\n  \"currency\": \"USD\",\n  \"external_order_id\": \"order-acme-00001\",\n  \"customer_reference\": \"cust-42\",\n  \"payment_method_token\": \"pm_tok_visa_4242\",\n  \"metadata\": {\n    \"order_note\": \"Birthday gift\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Initiates a new payment through the payment-domain service.\n\n**Required fields:** `amount` (integer, smallest currency unit e.g. cents), `currency` (ISO 4217, 3 chars), `external_order_id`\n**Optional fields:** `customer_reference`, `payment_method_token`, `metadata` (object)\n\n**Headers:**\n- `Idempotency-Key` — repeat the same value to receive the cached 201 response without creating a duplicate payment.\n- `X-Correlation-ID` — propagated to payment-domain and echoed back in the response body.\n\nThe post-response script saves `payment_id` into the collection variable."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"payment_id\": \"01HXYZ...\",\n  \"status\": \"pending\",\n  \"correlation_id\": \"local-test-001\"\n}"
            },
            {
              "name": "422 Validation error",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"The amount field is required. (and 2 more errors)\",\n  \"errors\": {\n    \"amount\": [\"The amount field is required.\"],\n    \"currency\": [\"The currency field is required.\"],\n    \"external_order_id\": [\"The external order id field is required.\"]\n  }\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Missing API key.\"\n}"
            },
            {
              "name": "429 Rate limit exceeded",
              "status": "Too Many Requests",
              "code": 429,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Too many requests.\",\n  \"retry_after\": 42\n}"
            }
          ]
        },
        {
          "name": "Initiate Payment — idempotency replay",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Accept",          "value": "application/json" },
              { "key": "Authorization",   "value": "Bearer {{api_key}}" },
              { "key": "Idempotency-Key", "value": "order-acme-00001" },
              { "key": "X-Correlation-ID","value": "local-test-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 9900,\n  \"currency\": \"USD\",\n  \"external_order_id\": \"order-acme-00001\",\n  \"customer_reference\": \"cust-42\",\n  \"payment_method_token\": \"pm_tok_visa_4242\",\n  \"metadata\": {\n    \"order_note\": \"Birthday gift\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Repeats the same `Idempotency-Key` as the previous request. The merchant-api returns the cached 201 response without forwarding to payment-domain."
          },
          "response": []
        },
        {
          "name": "Initiate Payment — missing required fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Omits all required fields. Expect 422 with validation errors for `amount`, `currency`, and `external_order_id`."
          },
          "response": []
        },
        {
          "name": "Initiate Payment — no auth",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 9900,\n  \"currency\": \"USD\",\n  \"external_order_id\": \"order-acme-00001\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Omits Authorization header. Expect 401 Missing API key."
          },
          "response": []
        },
        {
          "name": "Get Payment",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",           "value": "application/json" },
              { "key": "Authorization",    "value": "Bearer {{api_key}}" },
              { "key": "X-Correlation-ID", "value": "local-test-001", "description": "Optional. Propagated to payment-domain and echoed back in the response." }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/payments/{{payment_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "{{payment_id}}"]
            },
            "description": "Fetch the current state of a single payment owned by the authenticated merchant.\n\n**Path param:** `{id}` — payment ULID (use the `payment_id` collection variable set by Initiate Payment).\n\n**Response fields:** `payment_id`, `status`, `amount`, `currency`, `provider_reference`, `failure_reason` (null if never failed), `created_at`, `updated_at`, `correlation_id`.\n\nReturns 404 for unknown payments and payments belonging to other merchants (no existence leak)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"payment_id\": \"01knhswvgnty2g61yjgpqfk2tw\",\n  \"status\": \"initiated\",\n  \"amount\": 9900,\n  \"currency\": \"USD\",\n  \"provider_reference\": null,\n  \"failure_reason\": null,\n  \"created_at\": \"2026-04-08T10:00:00+00:00\",\n  \"updated_at\": \"2026-04-08T10:00:00+00:00\",\n  \"correlation_id\": \"local-test-001\"\n}"
            },
            {
              "name": "404 Not found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Payment not found.\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Missing API key.\"\n}"
            }
          ]
        },
        {
          "name": "Get Payment — not found",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/payments/00000000000000000000000000",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "00000000000000000000000000"]
            },
            "description": "Uses a non-existent payment ID. Expect 404."
          },
          "response": []
        },
        {
          "name": "Get Payment — no auth",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/payments/{{payment_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "{{payment_id}}"]
            },
            "description": "Omits Authorization header. Expect 401 Missing API key."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authenticated — Refunds",
      "item": [
        {
          "name": "Initiate Refund",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.refund_id) {",
                  "    pm.collectionVariables.set('refund_id', json.refund_id);",
                  "    console.log('refund_id saved:', json.refund_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Accept",          "value": "application/json" },
              { "key": "Authorization",   "value": "Bearer {{api_key}}" },
              { "key": "Idempotency-Key", "value": "refund-acme-00001", "description": "Optional. Repeat with the same value to get a cached response without creating a duplicate refund." },
              { "key": "X-Correlation-ID","value": "local-test-001",   "description": "Optional. Propagated to payment-domain and echoed back in the response." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_id\": \"{{payment_id}}\",\n  \"amount\": 1000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/refunds",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "refunds"]
            },
            "description": "Initiates a refund for an existing captured payment.\n\n**Required fields:** `payment_id` (ULID of the payment to refund), `amount` (integer, smallest currency unit e.g. cents)\n\n**Business rules enforced by payment-domain:**\n- Payment must exist and belong to the authenticated merchant.\n- Payment status must be `captured`.\n- Refund amount must not exceed the original payment amount.\n\n**Headers:**\n- `Idempotency-Key` — repeat the same value to receive the cached 201 response without creating a duplicate refund.\n- `X-Correlation-ID` — propagated to payment-domain and echoed back in the response body.\n\nThe post-response script saves `refund_id` into the collection variable."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"refund_id\": \"01HREF...\",\n  \"payment_id\": \"01HXYZ...\",\n  \"status\": \"pending\",\n  \"amount\": 1000,\n  \"currency\": \"USD\",\n  \"correlation_id\": \"local-test-001\"\n}"
            },
            {
              "name": "404 Payment not found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Payment not found.\"\n}"
            },
            {
              "name": "422 Payment not captured",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Payment status does not allow a refund.\",\n  \"errors\": {\n    \"payment_id\": [\"Only captured payments can be refunded.\"]\n  }\n}"
            },
            {
              "name": "422 Amount exceeds payment",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Refund amount exceeds the original payment amount.\",\n  \"errors\": {\n    \"amount\": [\"The refund amount must not exceed the original payment amount.\"]\n  }\n}"
            },
            {
              "name": "422 Validation error",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"The payment id field is required. (and 1 more error)\",\n  \"errors\": {\n    \"payment_id\": [\"The payment id field is required.\"],\n    \"amount\": [\"The amount field is required.\"]\n  }\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Missing API key.\"\n}"
            }
          ]
        },
        {
          "name": "Initiate Refund — idempotency replay",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Accept",          "value": "application/json" },
              { "key": "Authorization",   "value": "Bearer {{api_key}}" },
              { "key": "Idempotency-Key", "value": "refund-acme-00001" },
              { "key": "X-Correlation-ID","value": "local-test-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_id\": \"{{payment_id}}\",\n  \"amount\": 1000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/refunds",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "refunds"]
            },
            "description": "Repeats the same `Idempotency-Key` as the previous request. The merchant-api returns the cached 201 response without forwarding to payment-domain."
          },
          "response": []
        },
        {
          "name": "Initiate Refund — missing required fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/refunds",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "refunds"]
            },
            "description": "Omits all required fields. Expect 422 with validation errors for `payment_id` and `amount`."
          },
          "response": []
        },
        {
          "name": "Initiate Refund — no auth",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_id\": \"{{payment_id}}\",\n  \"amount\": 1000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/refunds",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "refunds"]
