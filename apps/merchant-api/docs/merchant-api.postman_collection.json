        },
        {
          "name": "Get Refund",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",           "value": "application/json" },
              { "key": "Authorization",    "value": "Bearer {{api_key}}" },
              { "key": "X-Correlation-ID", "value": "local-test-001", "description": "Optional. Propagated to payment-domain and included in the response." }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/refunds/{{refund_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "refunds", "{{refund_id}}"]
            },
            "description": "Fetch the current state of a single refund owned by the authenticated merchant.\n\n**Path param:** `{id}` — refund ULID (use the `refund_id` collection variable set by Initiate Refund).\n\n**Response fields:** `refund_id`, `payment_id`, `status`, `amount`, `currency`, `correlation_id`, `created_at`, `updated_at`.\n\nReturns 404 for unknown refunds and refunds belonging to other merchants (no existence leak)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"refund_id\": \"01HREF...\",\n  \"payment_id\": \"01HXYZ...\",\n  \"status\": \"pending\",\n  \"amount\": 1000,\n  \"currency\": \"USD\",\n  \"correlation_id\": \"6ba7b810-9dad-11d1-80b4-00c04fd430c8\",\n  \"created_at\": \"2026-04-08T10:00:00+00:00\",\n  \"updated_at\": \"2026-04-08T10:00:00+00:00\"\n}"
            },
            {
              "name": "404 Not found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Refund not found.\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Missing API key.\"\n}"
            }
          ]
        },
        {
          "name": "Get Refund — not found",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/refunds/00000000000000000000000000",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "refunds", "00000000000000000000000000"]
            },
            "description": "Uses a non-existent refund ID. Expect 404."
          },
          "response": []
        },
        {
          "name": "Get Refund — no auth",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/refunds/{{refund_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "refunds", "{{refund_id}}"]
            },
            "description": "Omits Authorization header. Expect 401 Missing API key."
          },
          "response": []
        }
