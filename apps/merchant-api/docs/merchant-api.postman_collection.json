    {
      "name": "Authenticated — API Key Rotation",
      "item": [
        {
          "name": "Rotate API Key (immediate)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.api_key && json.api_key.key) {",
                  "    pm.collectionVariables.set('api_key', json.api_key.key);",
                  "    console.log('api_key rotated to:', json.api_key.key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/api-keys/rotate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "api-keys", "rotate"]
            },
            "description": "Rotates the current API key. The old key is invalidated immediately (no grace period).\n\nThe post-response script updates the `api_key` collection variable with the new key automatically."
          },
          "response": [
            {
              "name": "201 Created — new key",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "_postman_previewlanguage": "json",
              "body": "{\n  \"api_key\": {\n    \"id\": \"01HDEF...\",\n    \"key\": \"pk_live_e5f6g7h8...\",\n    \"key_prefix\": \"pk_live_e5f6\",\n    \"created_at\": \"2026-04-06T10:05:00Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Rotate API Key (60-min grace period)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.api_key && json.api_key.key) {",
                  "    pm.collectionVariables.set('api_key', json.api_key.key);",
                  "    console.log('api_key rotated (grace 60m) to:', json.api_key.key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grace_minutes\": 60\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/api-keys/rotate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "api-keys", "rotate"]
            },
            "description": "Rotates the key but keeps the old key valid for 60 minutes. Useful for rolling deployments without downtime.\n\nValid range for `grace_minutes`: 0–1440 (up to 24 hours)."
          },
          "response": []
        },
