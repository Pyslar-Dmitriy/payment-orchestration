APP_NAME=payment-orchestrator
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=json
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=payment_orchestrator
DB_USERNAME=postgres
DB_PASSWORD=

QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=payment-orchestrator

CORRELATION_ID_HEADER=X-Correlation-ID

INTERNAL_SERVICE_SECRET=change-me-in-production

PAYMENT_DOMAIN_BASE_URL=http://payment-domain
PAYMENT_DOMAIN_CONNECT_TIMEOUT=2
PAYMENT_DOMAIN_TIMEOUT=5

PROVIDER_GATEWAY_BASE_URL=http://provider-gateway
PROVIDER_GATEWAY_CONNECT_TIMEOUT=2
PROVIDER_GATEWAY_TIMEOUT=30

LEDGER_SERVICE_BASE_URL=http://ledger-service
LEDGER_SERVICE_CONNECT_TIMEOUT=2
LEDGER_SERVICE_TIMEOUT=10

CALLBACK_DELIVERY_BASE_URL=http://merchant-callback-delivery
CALLBACK_DELIVERY_CONNECT_TIMEOUT=2
CALLBACK_DELIVERY_TIMEOUT=10
