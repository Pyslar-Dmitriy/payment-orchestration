# ──────────────────────────────────────────────────────────────────────────────
# Compose-level environment variables
# Copy this file to .env and fill in values before running `make up`.
# These variables configure the infrastructure containers themselves,
# NOT the Laravel application services (those use apps/<service>/.env).
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret

# RabbitMQ
RABBITMQ_DEFAULT_USER=rabbit
RABBITMQ_DEFAULT_PASS=rabbit

# Grafana
GRAFANA_ADMIN_PASSWORD=grafana
